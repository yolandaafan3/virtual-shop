@page
@model TiendaVirtual.Pages.IndexModel
@{
    ViewData["Title"] = "Inicio";
}

<section class="hero">
    <div class="hero-content">
        <div class="hero-badge">Sistema Tienda Virtual · POO</div>
        <h1 class="hero-title">Bienvenido a<br><em>NexStore</em></h1>
        <p class="hero-subtitle">Gestiona productos, clientes y pedidos con una arquitectura orientada a objetos completa.</p>
        <div class="hero-actions">
            <a asp-page="/Productos/Index" class="btn btn--primary btn--lg">Ver Productos</a>
            <a asp-page="/Productos/Crear" class="btn btn--outline btn--lg">+ Agregar Producto</a>
        </div>
    </div>
    <div class="hero-visual">
        <div class="hero-grid">
            <div class="hero-card">💻 <span>Tecnología</span></div>
            <div class="hero-card">👕 <span>Ropa</span></div>
            <div class="hero-card">🛒 <span>Alimentos</span></div>
        </div>
    </div>
</section>

<section class="stats-section">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-number">@Model.TotalProductos</div>
                <div class="stat-label">Productos</div>
                <div class="stat-icon">📦</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">@Model.TotalClientes</div>
                <div class="stat-label">Clientes</div>
                <div class="stat-icon">👥</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">@Model.TotalPedidos</div>
                <div class="stat-label">Pedidos</div>
                <div class="stat-icon">📋</div>
            </div>
            <div class="stat-card">
                <div class="stat-number">$@Model.VentasTotales.ToString("N0")</div>
                <div class="stat-label">En ventas</div>
                <div class="stat-icon">💰</div>
            </div>
        </div>
    </div>
</section>

<section class="categories-section">
    <div class="container">
        <h2 class="section-title">Categorías de Productos</h2>
        <div class="categories-grid">
            <a asp-page="/Productos/Index" asp-route-tipo="Tecnología" class="category-card category-card--tech">
                <div class="category-icon">💻</div>
                <h3>Tecnología</h3>
                <p>@Model.ConteoTipos.GetValueOrDefault("Tecnología") productos</p>
            </a>
            <a asp-page="/Productos/Index" asp-route-tipo="Ropa" class="category-card category-card--ropa">
                <div class="category-icon">👕</div>
                <h3>Ropa & Moda</h3>
                <p>@Model.ConteoTipos.GetValueOrDefault("Ropa") productos</p>
            </a>
            <a asp-page="/Productos/Index" asp-route-tipo="Alimento" class="category-card category-card--alimento">
                <div class="category-icon">🛒</div>
                <h3>Alimentos</h3>
                <p>@Model.ConteoTipos.GetValueOrDefault("Alimento") productos</p>
            </a>
        </div>
    </div>
</section>

<section class="recent-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Productos Recientes</h2>
            <a asp-page="/Productos/Index" class="btn btn--text">Ver todos →</a>
        </div>
        <div class="products-grid">
            @foreach (var p in Model.ProductosRecientes)
            {
                <div class="product-card">
                    <div class="product-card__header">
                        <span class="product-emoji">@p.IconoTipo</span>
                        <span class="badge badge--@p.ColorTipo">@p.TipoProducto</span>
                    </div>
                    <h3 class="product-card__name">@p.Nombre</h3>
                    <p class="product-card__desc">@p.Descripcion</p>
                    <div class="product-card__footer">
                        <span class="product-price">$@p.Precio.ToString("N2")</span>
                        <span class="product-stock @(p.HayStock() ? "stock--ok" : "stock--out")">
                            @(p.HayStock() ? $"Stock: {p.Stock}" : "Sin stock")
                        </span>
                    </div>
                    <div class="product-card__actions">
                        <a asp-page="/Productos/Detalle" asp-route-id="@p.Id" class="btn btn--sm btn--outline">Ver detalle</a>
                        @if (p.HayStock())
                        {
                            <form method="post" asp-page-handler="AgregarCarrito">
                                <input type="hidden" name="productoId" value="@p.Id" />
                                <button type="submit" class="btn btn--sm btn--primary">+ Carrito</button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</section>