@page
@model TiendaVirtual.Pages.Clientes.CrearModel
@{
    ViewData["Title"] = "Nuevo Cliente";
}

<div class="page-header">
    <div class="container">
        <div class="page-header__inner">
            <div>
                <h1 class="page-title">Nuevo Cliente</h1>
                <p class="page-subtitle">Registra un nuevo cliente en el sistema</p>
            </div>
            <a asp-page="/Clientes/Index" class="btn btn--outline">← Volver</a>
        </div>
    </div>
</div>

<div class="container">
    <div class="form-card form-card--sm">
        <form method="post">
            <div class="form-grid">
                <div class="form-group">
                    <label asp-for="Cliente.Nombre">Nombre *</label>
                    <input asp-for="Cliente.Nombre" class="form-control" placeholder="María" />
                    <span asp-validation-for="Cliente.Nombre" class="form-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Cliente.Apellido">Apellido *</label>
                    <input asp-for="Cliente.Apellido" class="form-control" placeholder="González" />
                    <span asp-validation-for="Cliente.Apellido" class="form-error"></span>
                </div>
                <div class="form-group form-group--full">
                    <label asp-for="Cliente.Email">Correo electrónico *</label>
                    <input asp-for="Cliente.Email" type="email" class="form-control" placeholder="ejemplo@correo.com" />
                    <span asp-validation-for="Cliente.Email" class="form-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Cliente.Telefono">Teléfono</label>
                    <input asp-for="Cliente.Telefono" class="form-control" placeholder="555-0101" />
                    <span asp-validation-for="Cliente.Telefono" class="form-error"></span>
                </div>
                <div class="form-group form-group--full">
                    <label asp-for="Cliente.Direccion">Dirección</label>
                    <input asp-for="Cliente.Direccion" class="form-control" placeholder="Calle, ciudad..." />
                </div>
            </div>
            <div class="form-actions">
                <a asp-page="/Clientes/Index" class="btn btn--outline">Cancelar</a>
                <button type="submit" class="btn btn--primary">Registrar Cliente 👤</button>
            </div>
        </form>
    </div>
</div>